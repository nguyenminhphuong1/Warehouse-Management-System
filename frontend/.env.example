# .env.example - Environment Configuration Template
# Copy this file to .env and update values for your environment

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
NODE_ENV=development
DEBUG=True
BUILD_TARGET=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
MYSQL_ROOT_PASSWORD=warehouse_root_2024
MYSQL_DATABASE=warehouse_db
MYSQL_USER=warehouse_user
MYSQL_PASSWORD=warehouse_pass_2024
MYSQL_PORT=3306

# Database URL for Django
DATABASE_URL=mysql://warehouse_user:warehouse_pass_2024@localhost:3306/warehouse_db

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# DJANGO BACKEND CONFIGURATION
# =============================================================================
SECRET_KEY=your-very-secret-key-change-this-in-production
BACKEND_PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security Settings
SECURE_SSL_REDIRECT=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# Session Settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# CSRF Settings
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True

# =============================================================================
# REACT FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WEBSOCKET_URL=ws://localhost:8000/ws
GENERATE_SOURCEMAP=false

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Email Templates
EMAIL_SUBJECT_PREFIX=[Warehouse Management]

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# Local Storage (default)
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
STATICFILES_STORAGE=django.contrib.staticfiles.storage.StaticFilesStorage

# AWS S3 Storage (production)
# DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
# STATICFILES_STORAGE=storages.backends.s3boto3.S3StaticStorage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=warehouse-management-bucket
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com
AWS_DEFAULT_ACL=public-read

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
REACT_APP_SENTRY_DSN=https://your-frontend-sentry-dsn@sentry.io/project-id

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================
CELERY_ALWAYS_EAGER=False
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Ho_Chi_Minh
CELERY_ENABLE_UTC=True

# Celery Beat Settings
CELERY_BEAT_SCHEDULE_FILENAME=celerybeat-schedule

# =============================================================================
# NGINX & WEB SERVER CONFIGURATION
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=100M

# SSL Configuration
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Flower (Celery Monitoring)
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin123

# Elasticsearch & Kibana
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# Prometheus & Grafana
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin123

# Google Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# =============================================================================
# WAREHOUSE SPECIFIC CONFIGURATION
# =============================================================================
# Default warehouse settings
DEFAULT_WAREHOUSE_CAPACITY=1000
DEFAULT_PALLET_CAPACITY=100
DEFAULT_EXPIRY_WARNING_DAYS=7
DEFAULT_QUALITY_CHECK_INTERVAL=30

# QR Code Settings
QR_CODE_SIZE=256
QR_CODE_ERROR_CORRECTION=M
QR_CODE_BORDER=4

# Barcode Settings
BARCODE_FORMAT=CODE128
BARCODE_WIDTH=2
BARCODE_HEIGHT=30

# Audio Settings
AUDIO_SUCCESS_VOLUME=0.8
AUDIO_ERROR_VOLUME=0.9
AUDIO_FORMAT=mp3

# =============================================================================
# BUSINESS LOGIC CONFIGURATION
# =============================================================================
# Inventory Management
LOW_STOCK_THRESHOLD=10
REORDER_POINT_MULTIPLIER=2
SAFETY_STOCK_DAYS=7

# FIFO Settings
ENABLE_FIFO=True
FIFO_TOLERANCE_DAYS=3
PRIORITY_EXPIRY_DAYS=30

# Temperature & Humidity Monitoring
TEMP_ALERT_ENABLED=True
TEMP_MIN_THRESHOLD=0
TEMP_MAX_THRESHOLD=40
HUMIDITY_MIN_THRESHOLD=30
HUMIDITY_MAX_THRESHOLD=80

# Maintenance Settings
MAINTENANCE_REMINDER_DAYS=7
MAINTENANCE_OVERDUE_DAYS=30
AUTO_MAINTENANCE_SCHEDULING=True

# =============================================================================
# API RATE LIMITING
# =============================================================================
API_RATE_LIMIT_ENABLED=True
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_BURST=10

# API Cache Settings
API_CACHE_TIMEOUT=300
API_CACHE_KEY_PREFIX=warehouse_api

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Database Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups
BACKUP_COMPRESS=True

# File Backup
FILE_BACKUP_ENABLED=True
FILE_BACKUP_EXCLUDE_PATTERNS=*.log,*.tmp,node_modules/*

# Remote Backup (S3)
REMOTE_BACKUP_ENABLED=False
REMOTE_BACKUP_BUCKET=warehouse-backups
REMOTE_BACKUP_ENCRYPTION=True

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Email Notifications
EMAIL_NOTIFICATIONS_ENABLED=True
ADMIN_EMAIL=admin@company.com
NOTIFICATION_EMAIL_TEMPLATE_DIR=templates/emails

# SMS Notifications (optional)
SMS_ENABLED=False
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
PUSH_NOTIFICATIONS_ENABLED=False
FCM_SERVER_KEY=your-fcm-server-key

# Slack Integration
SLACK_ENABLED=False
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#warehouse-alerts

# =============================================================================
# INTEGRATION SETTINGS
# =============================================================================
# ERP Integration
ERP_INTEGRATION_ENABLED=False
ERP_API_URL=https://your-erp-system.com/api
ERP_API_KEY=your-erp-api-key
ERP_SYNC_INTERVAL=3600

# Accounting System Integration
ACCOUNTING_INTEGRATION_ENABLED=False
ACCOUNTING_API_URL=https://your-accounting-system.com/api
ACCOUNTING_API_KEY=your-accounting-api-key

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Debug Settings
DEBUG_TOOLBAR=True
DEBUG_PROFILING=False
DEBUG_SQL_QUERIES=False

# Test Settings
TEST_DATABASE_NAME=test_warehouse_db
TEST_RUNNER=django.test.runner.DiscoverRunner
TEST_COVERAGE_REPORT=True

# Development Tools
HOT_RELOAD=True
AUTO_MIGRATION=True
FIXTURE_LOADING=True

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# Performance Settings
DJANGO_SETTINGS_MODULE=config.settings.production
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Cache Settings
CACHE_BACKEND=redis
CACHE_LOCATION=redis://redis:6379/3
CACHE_TIMEOUT=3600
CACHE_KEY_PREFIX=warehouse_cache

# Session Settings (Production)
SESSION_REDIS_HOST=redis
SESSION_REDIS_PORT=6379
SESSION_REDIS_DB=4

# Static Files (Production)
STATIC_ROOT=/var/www/static
MEDIA_ROOT=/var/www/media
STATIC_URL=/static/
MEDIA_URL=/media/

# =============================================================================
# SECURITY SETTINGS (PRODUCTION)
# =============================================================================
# HTTPS Settings
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Cookie Security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Content Security Policy
CSP_ENABLED=True
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_FONT_SRC='self' https://fonts.gstatic.com

# =============================================================================
# CUSTOM APPLICATION SETTINGS
# =============================================================================
# Company Information
COMPANY_NAME=Warehouse Management Company
COMPANY_ADDRESS=123 Business Street, City, Country
COMPANY_PHONE=+84-123-456-789
COMPANY_EMAIL=contact@company.com
COMPANY_WEBSITE=https://company.com

# Application Branding
APP_NAME=Warehouse Management System
APP_VERSION=1.0.0
APP_DESCRIPTION=Hệ thống Quản lý Xuất Nhập Kho Thông minh
APP_LOGO_URL=/static/images/logo.png
APP_FAVICON_URL=/static/images/favicon.ico

# Localization
DEFAULT_LANGUAGE=vi
TIMEZONE=Asia/Ho_Chi_Minh
DATE_FORMAT=d/m/Y
TIME_FORMAT=H:i:s
DATETIME_FORMAT=d/m/Y H:i:s

# Currency Settings
DEFAULT_CURRENCY=VND
CURRENCY_SYMBOL=₫
CURRENCY_DECIMAL_PLACES=0

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Module Enablement
ENABLE_MODULE_NHAP_HANG=True
ENABLE_MODULE_TAO_DON=True
ENABLE_MODULE_XUAT_HANG=True
ENABLE_MODULE_QUAN_LY_KHO=True
ENABLE_MODULE_KIEM_TRA_GIAO_HANG=True

# Advanced Features
ENABLE_BARCODE_SCANNING=True
ENABLE_QR_CODE_GENERATION=True
ENABLE_AUDIO_ALERTS=True
ENABLE_GPS_TRACKING=False
ENABLE_CAMERA_INTEGRATION=False
ENABLE_IOT_SENSORS=False
ENABLE_AI_RECOMMENDATIONS=False
ENABLE_BLOCKCHAIN_TRACKING=False

# Reporting Features
ENABLE_ADVANCED_REPORTS=True
ENABLE_REAL_TIME_DASHBOARD=True
ENABLE_EXPORT_EXCEL=True
ENABLE_EXPORT_PDF=True
ENABLE_SCHEDULED_REPORTS=True

# =============================================================================
# MAINTENANCE MODE
# =============================================================================
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=Hệ thống đang bảo trì. Vui lòng quay lại sau.
MAINTENANCE_ALLOWED_IPS=127.0.0.1,localhost
MAINTENANCE_BYPASS_KEY=maintenance_bypass_2024